---
import BrandMark from "./BrandMark.astro";

interface Props {
  size?: string;
  href?: string;
  class?: string;
}

const { size = "36px", href, class: className } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  {...href ? { href } : {}}
  class:list={["brand-logo", className]}
  style={`--logo-size: ${size}`}
>
  <BrandMark size="var(--logo-size)" />
  <div class="brand-logo__lockup">
    <div class="brand-logo__word">
      <span class="accent">AGENTIC</span> ASSEMBLY
    </div>
    <div class="brand-logo__tag">AI Engineers Support Group Osaka</div>
  </div>
</Tag>

<style>
  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: calc(var(--logo-size) * 0.5);
    color: inherit;
    text-decoration: none;
    border: none;
  }
  a.brand-logo:hover {
    color: inherit;
    border: none;
  }

  .brand-logo__lockup {
    line-height: 1;
  }

  .brand-logo__word {
    font-family: var(--mono);
    font-weight: 800;
    font-size: calc(var(--logo-size) * 0.558);
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }
  .brand-logo__word .accent {
    color: var(--accent);
  }

  .brand-logo__tag {
    font-family: var(--mono);
    font-weight: 400;
    font-size: calc(var(--logo-size) * 0.285);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-top: calc(var(--logo-size) * 0.119);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .brand-logo {
      --logo-size: 26px;
    }
  }
</style>
