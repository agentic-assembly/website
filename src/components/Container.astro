---
interface Props {
  class?: string;
  as?: keyof HTMLElementTagNameMap;
}
const { class: className, as: Tag = "div" } = Astro.props;
---

<Tag class:list={["container", className]}>
  <slot />
</Tag>

<style>
  .container {
    width: 100%;
    max-width: var(--page);
    margin-inline: auto;
    padding-inline: var(--gutter);
    box-sizing: border-box;
  }
</style>
