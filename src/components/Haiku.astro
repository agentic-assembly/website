---
interface Line {
  text: string;
  why: string;
}
interface Props {
  lines: Line[];
  date?: string;
  model?: string;
}
const { lines, date, model } = Astro.props;
const id = `haiku-${Math.random().toString(36).slice(2, 8)}`;
const showSig = Boolean(date || model);
---

<div class="haiku">
  <input type="checkbox" id={id} class="haiku__toggle" />
  <div class="haiku__quote">
    {
      lines.map((l, i) => (
        <div class="haiku__row">
          <span class="haiku__line">
            {l.text}
            {i < lines.length - 1 ? " —" : ""}
          </span>
          <span class="haiku__why">{l.why}</span>
        </div>
      ))
    }
  </div>
  <div class="haiku__footer">
    {
      showSig && (
        <span class="haiku__sig">
          — AA H-AI-KU
          {date && <> — {date}</>}
          {model && <> — {model}</>}
        </span>
      )
    }
    <label for={id} class="haiku__wtf">
      <span class="haiku__wtf-trigger">WTF?</span>
    </label>
  </div>
</div>

<style>
  .haiku {
    position: relative;
    border-left: 2px solid var(--accent);
    background: color-mix(in oklch, var(--accent), transparent 92%);
    padding: 28px 32px 18px 32px;
    margin: 26px 0;
  }

  .haiku__toggle {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .haiku__quote {
    font-size: 32px;
    line-height: 1.25;
    font-style: italic;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .haiku__row {
    margin: 0 0 14px;
  }
  .haiku__row:last-child {
    margin-bottom: 0;
  }
  .haiku:has(.haiku__toggle:checked) .haiku__row {
    margin-bottom: 18px;
  }
  .haiku__line {
    display: inline;
  }
  .haiku__why {
    display: none;
    margin-top: 4px;
    font-family: var(--sans);
    font-style: normal;
    font-size: 13px;
    line-height: 1.55;
    letter-spacing: 0;
    color: var(--ink-dim);
  }
  .haiku__toggle:checked ~ .haiku__quote .haiku__why {
    display: block;
  }

  .haiku__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-top: 22px;
    min-height: 16px;
  }
  .haiku__sig {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-dim);
    letter-spacing: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .haiku__footer:has(.haiku__sig) .haiku__wtf {
    margin-left: auto;
  }

  .haiku__wtf {
    cursor: pointer;
    flex-shrink: 0;
  }
  .haiku__wtf-trigger {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px dashed var(--ink-dim);
    padding-bottom: 1px;
    transition:
      color 0.12s,
      border-color 0.12s;
  }
  .haiku__wtf:hover .haiku__wtf-trigger,
  .haiku__toggle:focus-visible ~ .haiku__footer .haiku__wtf .haiku__wtf-trigger,
  .haiku__toggle:checked ~ .haiku__footer .haiku__wtf .haiku__wtf-trigger {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 600px) {
    .haiku__quote {
      font-size: 22px;
    }
    .haiku {
      padding: 20px 22px 14px 22px;
    }
    .haiku__sig {
      font-size: 12px;
    }
  }
</style>
