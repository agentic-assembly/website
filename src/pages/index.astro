---
import { getCollection } from "astro:content";
import BrandMark from "../components/BrandMark.astro";
import Container from "../components/Container.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import { partsRecord } from "../lib/date";

const now = new Date();
const all = (await getCollection("assemblies")).sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);

const past = all.filter((e) => e.data.date < now).reverse();
const upcoming = all.filter((e) => e.data.date >= now).slice(0, 5);

const totalPast = past.length;
const pastDateFmt = new Intl.DateTimeFormat("en-GB", {
  day: "2-digit",
  month: "short",
  year: "2-digit",
});

const pastRows = past.map((entry, i) => {
  const n = totalPast - i;
  return {
    id: `AA${String(n).padStart(3, "0")}`,
    date: pastDateFmt.format(entry.data.date),
    title: entry.data.title,
    href: `/${n}`,
  };
});

const upcomingDateFmt = new Intl.DateTimeFormat("en-GB", {
  weekday: "short",
  day: "2-digit",
  month: "short",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
  timeZone: "Asia/Tokyo",
});

const formatUpcomingDate = (d: Date) => {
  const p = partsRecord(upcomingDateFmt, d);
  return `${p.weekday.toUpperCase()} ${p.day} ${p.month.toUpperCase()} — ${p.hour}:${p.minute}`;
};

const relativeSoon = (d: Date) => {
  const ms = d.getTime() - now.getTime();
  const days = Math.round(ms / 86_400_000);
  if (days <= 0) return "today";
  if (days === 1) return "tomorrow";
  if (days < 14) return `in ${days} days`;
  const weeks = Math.round(days / 7);
  return `in ${weeks} weeks`;
};

const upcomingRows = upcoming.map((entry, i) => {
  const n = totalPast + 1 + i;
  const id = `AA${String(n).padStart(3, "0")}`;
  const label = entry.data.summary ?? entry.data.title;
  return {
    id,
    date: formatUpcomingDate(entry.data.date),
    topic: label === id ? undefined : label,
    isNext: i === 0,
    soon: i === 0 ? relativeSoon(entry.data.date) : undefined,
    href: `/${n}`,
  };
});
---

<Layout title="Agentic Assembly — AI Engineers Support Group Osaka">
  <Header />

  <main>
    <section class="hero">
      <Container>
        <div class="hero__eyebrow">
          <span>
            <span class="nb">Agentic Engineering</span> — <span class="nb">Every Saturday</span> — <span class="nb">Osaka</span>
          </span>
        </div>
        <h1 class="hero__title">
          Engineers sitting together each Saturday — to compare notes on
          building with <span class="accent">agentic coding tools</span>.
        </h1>
        <dl class="hero__meta">
          <dt>Format</dt>
          <dd>Free Talk Round Table Discussion</dd>
          <dt>When</dt>
          <dd><span class="nb">Every Saturday</span>, 10:00 — 12:00 JST</dd>
          <dt>Where</dt>
          <dd>
            The DECK — 1F, 2-1-1 Minamihonmachi, Chuo-ku, Osaka —{" "}
            <a
              class="hero__meta-link"
              href="https://www.google.com/maps/search/?api=1&query=The+DECK+Minamihonmachi+Osaka"
              target="_blank"
              rel="noopener"
            >
              Map ↗
            </a>
          </dd>
          <dt>What</dt>
          <dd>Claude Code, Codex, Cursor, Cline, Aider, Opencode, OpenClaw, ...</dd>
          <dt>Cost</dt>
          <dd>Free.</dd>
        </dl>
      </Container>
    </section>

    <section class="section">
      <Container>
        <header class="section__head">
          <h2 class="section__title">Upcoming</h2>
        </header>

        <ol class="tl-list">
          {
            upcomingRows.map((item) => (
              <li class={`tl-item${item.isNext ? " tl-item--next" : ""}`}>
                <a href={item.href} class="tl-link">
                  <BrandMark class="tl-mark" size="18px" rotate={90} />
                  <div class="tl-id">
                    {item.id}
                    {item.soon && <span class="tl-soon">— {item.soon}</span>}
                  </div>
                  <div class="tl-date">{item.date}</div>
                  {item.topic && <div class="tl-topic">{item.topic}</div>}
                </a>
              </li>
            ))
          }
        </ol>
      </Container>
    </section>

    {totalPast > 0 && (
      <section class="section">
        <Container>
          <header class="section__head">
            <h2 class="section__title">Past assemblies</h2>
            <span class="section__count">
              {String(totalPast).padStart(3, "0")} / archive
            </span>
          </header>

          <div class="assemblies">
            {pastRows.map((row) => (
              <a href={row.href} class="assembly-row">
                <span class="assembly-row__id">{row.id}</span>
                <span class="assembly-row__date">{row.date}</span>
                <span class="assembly-row__title">{row.title}</span>
                <span class="assembly-row__loc" />
                <span class="assembly-row__arrow">→</span>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}
  </main>

  <Footer />
</Layout>
